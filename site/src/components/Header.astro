---
import config from 'virtual:starlight/user-config';
import Search from '@astrojs/starlight/components/Search.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';

const github = config.social?.find((s) => s.icon === 'github')?.href;
const shouldRenderSearch =
	config.pagefind ||
	config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="hdr">
	<a class="brand" href="/">
		<img class="mark" src="/icon.svg" alt="" width="24" height="24" />
		<span>Arcagrad</span>
	</a>

	<div class="right">
		<nav class="links">
			<a href="/">Home</a>
			{github && <a href={github}>GitHub</a>}
		</nav>
		{shouldRenderSearch && <div class="search sl-flex print:hidden"><Search /></div>}
		<ThemeSelect />
	</div>
</div>

<style>
	.hdr {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		height: 100%;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 9px;
		font-weight: 600;
		font-size: 1.05rem;
		letter-spacing: -0.01em;
		color: var(--sl-color-white);
		text-decoration: none;
		overflow: clip;
		min-width: 0;
		padding: 0.25rem;
		margin: -0.25rem;
	}
	.brand .mark {
		width: 24px;
		height: 24px;
		border-radius: 6px;
		display: block;
	}
	.right {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.links {
		display: flex;
		align-items: center;
		gap: 24px;
		font-size: 0.9rem;
		color: var(--sl-color-gray-3);
	}
	.links a {
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition: color 0.15s;
	}
	.links a:hover {
		color: var(--sl-color-white);
	}
	.search {
		width: clamp(8rem, 22vw, 15rem);
	}
	.search :global(button) {
		width: 100%;
	}
	@media (max-width: 50rem) {
		.links {
			display: none;
		}
		.search {
			width: auto;
		}
	}
</style>
