---
const repo = 'https://github.com/KalininG/arcagrad';
const SITE_URL = 'https://arcagrad.com';
const TITLE = 'Arcagrad — self-hosted comic, manga & book server';
const DESC =
	'A self-hosted server and reader for comics, manga, and books — built in Rust for large libraries and multiple users.';

const rows = [
	{
		eyebrow: 'Read',
		title: 'One reader for everything you collect',
		body: 'Paginated comics and manga, or reflowable EPUB books — Arcagrad automatically opens every item in the right reader. Per-user progress syncs across devices, so you pick up exactly where you left off.',
		img: '/reader.webp',
		alt: 'Arcagrad reader showing a wide double-page comic spread',
	},
	{
		eyebrow: 'Organize',
		title: 'Rich metadata, tags, and series — your originals kept intact',
		body: 'Standalone works and multi-volume series live in one mixed library. Namespaced tags, scraped metadata, and fast search across titles, creators, and tags make a 100k-item shelf feel small. Arcagrad never rewrites the contents of your existing files.',
		img: '/detail.webp',
		alt: 'Arcagrad item detail page — cover, author, description, tags, and reading overview',
	},
	{
		eyebrow: 'Plugins',
		title: 'An app store for metadata, downloads, and more',
		body: 'Install plugins from a repository to browse a source, download new items straight into your library, pull rich metadata, and follow series for new releases. Bundled plugins work out of the box, and community developers can create their own — each one sandboxed so it can only do what you allow.',
		chips: ['Browse', 'Download', 'Metadata', 'Follow releases'],
		img: '/plugins.webp',
		alt: 'Arcagrad plugins page — installed source plugins with versions and capabilities',
	},
	{
		eyebrow: 'Discover',
		title: 'Browse a whole source, right inside your library',
		body: 'Install a source plugin and browse its catalog without leaving Arcagrad — here, thousands of free classics from Project Gutenberg. Popular and recent feeds, a live filter, and “owned” badges so you never grab a duplicate. One click pulls a title into your library with its metadata attached.',
		img: '/discover.webp',
		alt: 'Arcagrad browse page showing a plugin source’s catalog of classic book covers',
	},
	{
		eyebrow: 'Track',
		title: 'Never miss a new release',
		body: 'Follow the series in your library and Arcagrad keeps a running calendar of what’s coming — upcoming volumes with print and digital dates, plus new uploads from the sources you follow. It refreshes on its own, so you always know what’s next.',
		img: '/calendar.webp',
		alt: 'Arcagrad tracking page listing upcoming volume releases with print and digital dates',
	},
	{
		eyebrow: 'Make it yours',
		title: 'A profile that’s yours, with the stats to match',
		body: 'A custom avatar and banner, personal favorites and star ratings, and reading stats that track what you’ve finished and what’s next. Every account gets its own space — this is a multi-user server, after all.',
		img: '/profile.webp',
		alt: 'Arcagrad profile page with a custom banner, avatar, reading stat cards, and an activity heatmap',
	},
];

const grid = [
	{
		t: 'Manga and books together',
		d: 'Keep manga, comics, and EPUB books in one mixed library, without creating a separate library for every type.',
		icon: '<path d="M12 3 3 8l9 5 9-5-9-5z"/><path d="M3 12l9 5 9-5"/><path d="M3 16l9 5 9-5"/>',
	},
	{
		t: 'Organizes itself',
		d: 'Arcagrad watches your folders, detects new and moved files, generates covers, and keeps everything searchable automatically.',
		icon: '<path d="M20 11A8.1 8.1 0 0 0 4.5 9M4 5v4h4"/><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>',
	},
	{
		t: 'Discover without leaving the app',
		d: 'Browse external catalogs, preview titles, and download them directly through optional community plugins.',
		icon: '<circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2.2 4.8-4.8 2.2 2.2-4.8z"/>',
	},
	{
		t: 'Never miss what comes next',
		d: 'Track series, follow searches, and see upcoming releases from your connected sources.',
		icon: '<rect x="4" y="5" width="16" height="16" rx="2"/><path d="M8 3v4M16 3v4M4 11h16"/>',
	},
	{
		t: 'Recommendations that stay private',
		d: 'Get suggestions from your own collection and reading activity — your library never goes to an external recommendation service.',
		icon: '<path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
	},
	{
		t: 'A separate experience for every reader',
		d: 'Each person gets their own account, reading progress, favorites, ratings, and recommendations.',
		icon: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.4a3 3 0 0 1 0 5.2M20.5 20a5.5 5.5 0 0 0-3.6-5.1"/>',
	},
];

const tech = [
	'Distributed as one Docker image',
	'Low and predictable memory use',
	'Built for libraries with 100,000+ items',
	'Sandboxed community plugins',
	'Documented REST API',
	'Back up one data directory',
];

const dims = {
	'/reader.webp': [1600, 925],
	'/detail.webp': [1600, 925],
	'/plugins.webp': [1600, 981],
	'/discover.webp': [1600, 1082],
	'/calendar.webp': [1600, 1081],
	'/profile.webp': [1600, 1085],
};

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="canonical" href={SITE_URL} />
		<title>{TITLE}</title>
		<meta name="description" content={DESC} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Arcagrad" />
		<meta property="og:title" content={TITLE} />
		<meta property="og:description" content={DESC} />
		<meta property="og:url" content={SITE_URL} />
		<meta property="og:image" content={`${SITE_URL}/og.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Arcagrad — your library, your server" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={TITLE} />
		<meta name="twitter:description" content={DESC} />
		<meta name="twitter:image" content={`${SITE_URL}/og.png`} />

		<style>
			:root {
				--bg: #13151a;
				--bg-2: #191c22;
				--surface: #1a1d24;
				--border: #282c34;
				--border-2: #353a44;
				--text: #eceef2;
				--muted: #969ba6;
				--faint: #666c76;
				--accent: #cf6247;
				--accent-2: #e07d63;
				--radius: 14px;
				--maxw: 1280px;
				--font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
				--mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			}
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: var(--font);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
			}
			a { color: inherit; text-decoration: none; }
			.wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

			header {
				position: sticky; top: 0; z-index: 10;
				backdrop-filter: blur(10px);
				background: color-mix(in srgb, var(--bg) 78%, transparent);
				border-bottom: 1px solid var(--border);
			}
			.nav { display: flex; align-items: center; justify-content: space-between; height: 62px; }
			.brand { display: flex; align-items: center; gap: 9px; font-weight: 600; font-size: 1.05rem; letter-spacing: -0.01em; }
			.brand .mark { width: 24px; height: 24px; border-radius: 6px; display: block; }
			.nav-links { display: flex; align-items: center; gap: 26px; font-size: 0.9rem; color: var(--muted); }
			.nav-links a:hover { color: var(--text); }
			.btn {
				display: inline-flex; align-items: center; gap: 8px;
				padding: 10px 18px; border-radius: 10px; font-weight: 500; font-size: 0.9rem;
				border: 1px solid var(--border-2); background: transparent; color: var(--text);
				cursor: pointer; transition: background .15s, border-color .15s, transform .05s;
			}
			.btn:hover { background: var(--bg-2); border-color: var(--faint); }
			.btn:active { transform: translateY(1px); }
			.btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
			.btn.primary:hover { background: var(--accent-2); border-color: var(--accent-2); }
			.btn.sm { padding: 8px 14px; }

			.hero { position: relative; text-align: center; padding: 92px 0 40px; overflow: hidden; }
			.glow {
				position: absolute; top: -180px; left: 50%; transform: translateX(-50%);
				width: 780px; height: 480px; pointer-events: none;
				background: radial-gradient(closest-side, rgba(207,98,71,0.10), transparent 72%);
				filter: blur(24px);
			}
			h1 {
				margin: 0 auto; max-width: 15ch; font-size: clamp(2.6rem, 6vw, 4.4rem);
				line-height: 1.04; letter-spacing: -0.03em; font-weight: 650;
			}
			h1 .accent { color: var(--accent); }
			.sub { margin: 22px auto 0; max-width: 56ch; font-size: clamp(1.02rem, 1.6vw, 1.22rem); color: var(--muted); }
			.cta { display: flex; gap: 12px; justify-content: center; margin-top: 34px; flex-wrap: wrap; }

			.frame {
				border: 1px solid var(--border-2); border-radius: var(--radius);
				background: var(--surface); overflow: hidden;
				box-shadow: 0 30px 80px -30px rgba(0,0,0,0.8);
			}
			.frame-body { position: relative; }

			.hero-frame { max-width: 980px; margin: 54px auto 0; }

			.showcase { padding-top: 40px; padding-bottom: 20px; display: flex; flex-direction: column; gap: 88px; margin-top: 60px; }
			.row { display: grid; grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.45fr); gap: 44px; align-items: center; }
			.row:nth-child(even) { grid-template-columns: minmax(0, 1.45fr) minmax(0, 0.78fr); }
			.row:nth-child(even) .row-text { order: 2; }
			.eyebrow { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); }
			.row-text h2 { margin: 12px 0 0; font-size: clamp(1.5rem, 2.3vw, 2rem); line-height: 1.16; letter-spacing: -0.02em; font-weight: 600; }
			.row-text p { margin: 14px 0 0; color: var(--muted); font-size: 1.02rem; }
			.shot-frame {
				border: 1px solid var(--border-2); border-radius: var(--radius); overflow: hidden;
				background: var(--surface); box-shadow: 0 24px 60px -34px rgba(0,0,0,0.85);
			}

			.ph {
				aspect-ratio: 1.73; display: flex; flex-direction: column;
				align-items: center; justify-content: center; gap: 8px; text-align: center;
				background:
					repeating-linear-gradient(45deg, rgba(255,255,255,0.015) 0 12px, transparent 12px 24px),
					var(--bg-2);
				color: var(--faint);
			}
			.ph .ico { width: 30px; height: 30px; opacity: 0.7; }
			.ph .lbl { font-size: 0.86rem; color: var(--muted); }
			.ph .hint { font-size: 0.72rem; }
			.shot-img { display: block; width: 100%; height: auto; }
			.chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
			.chip { font-size: 0.8rem; color: var(--muted); background: var(--bg-2); border: 1px solid var(--border); border-radius: 999px; padding: 6px 13px; }

			.features { padding-top: 108px; padding-bottom: 20px; }
			.features h2 { text-align: center; font-size: clamp(1.6rem, 2.6vw, 2.1rem); letter-spacing: -0.02em; margin: 0; font-weight: 600; }
			.features .lead { text-align: center; color: var(--muted); margin: 12px auto 0; max-width: 52ch; }
			.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-top: 48px; }
			.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; }
			.card .icon { width: 34px; height: 34px; border-radius: 9px; background: var(--bg-2); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; color: var(--accent); }
			.card h3 { margin: 0 0 6px; font-size: 1.02rem; font-weight: 600; }
			.card p { margin: 0; color: var(--muted); font-size: 0.92rem; }

			.tech { padding-top: 52px; padding-bottom: 20px; }
			.tech h2 { text-align: center; font-size: clamp(1.25rem, 1.9vw, 1.55rem); letter-spacing: -0.01em; margin: 0 0 30px; font-weight: 600; }
			.tech-list { list-style: none; margin: 0 auto; padding: 0; max-width: 800px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px 30px; }
			.tech-list li { display: flex; align-items: center; gap: 10px; color: var(--muted); font-size: 0.94rem; }
			.tech-list svg { width: 16px; height: 16px; flex: none; color: var(--accent); }

			.quick { padding-top: 108px; padding-bottom: 40px; }
			.quick-inner { max-width: 760px; margin: 0 auto; text-align: center; }
			.quick h2 { font-size: clamp(1.6rem, 2.6vw, 2.1rem); letter-spacing: -0.02em; margin: 0; font-weight: 600; }
			.quick p { color: var(--muted); margin: 12px 0 28px; }
			.terminal { text-align: left; border: 1px solid var(--border-2); border-radius: var(--radius); overflow: hidden; }
			.terminal pre { margin: 0; padding: 20px 22px; background: #0b0b0d; color: #e8e8ea; font-family: var(--mono); font-size: 0.86rem; line-height: 1.7; overflow-x: auto; }
			.terminal .cmt { color: var(--faint); }
			.terminal .flag { color: var(--accent-2); }

			footer { border-top: 1px solid var(--border); margin-top: 80px; padding: 40px 0; color: var(--faint); font-size: 0.86rem; }
			.foot { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
			.foot a { color: var(--muted); }
			.foot a:hover { color: var(--text); }

			@media (max-width: 820px) {
				.nav-links .hide-sm { display: none; }
				.row, .row:nth-child(even) { grid-template-columns: 1fr; gap: 26px; }
				.row:nth-child(even) .row-text { order: 0; }
				.hero { padding-top: 64px; }
			}
		</style>
	</head>

	<body>
		<header>
			<div class="wrap nav">
				<div class="brand"><img class="mark" src="/icon.svg" alt="" width="24" height="24" /> Arcagrad</div>
				<nav class="nav-links">
					<a class="hide-sm" href="/getting-started/introduction/">Docs</a>
					<a class="hide-sm" href="/download/">Download</a>
					<a class="hide-sm" href={repo}>GitHub</a>
					<a class="btn sm primary" href="/getting-started/install/">Get started</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero">
				<div class="glow"></div>
				<div class="wrap">
					<h1>Your library, your server</h1>
					<p class="sub">
						Read comics, manga, and books in one private library. Discover new titles,
						track upcoming releases, and get personal recommendations — all from your own server.
					</p>
					<div class="cta">
						<a class="btn primary" href="/getting-started/install/">Install with Docker</a>
						<a class="btn" href="/download/">Download client app</a>
						<a class="btn" href={repo}>View on GitHub</a>
					</div>
					<div class="frame hero-frame">
						<div class="frame-body">
							<img class="shot-img" src="/home.webp" alt="Arcagrad library home — sidebar, a continue-reading shelf, and a grid of covers" width="1920" height="1091" />
						</div>
					</div>
				</div>
			</section>

			<section class="wrap showcase">
				{rows.map((r) => (
					<div class="row">
						<div class="row-text">
							<span class="eyebrow">{r.eyebrow}</span>
							<h2>{r.title}</h2>
							<p>{r.body}</p>
							{r.chips && (
								<div class="chips">
									{r.chips.map((c) => (<span class="chip">{c}</span>))}
								</div>
							)}
						</div>
						<div class="shot-frame">
							{r.img ? (
								<img class="shot-img" src={r.img} alt={r.alt} width={dims[r.img]?.[0]} height={dims[r.img]?.[1]} loading="lazy" />
							) : (
								<div class="ph">
									<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 18v2M16 18v2"/></svg>
									<span class="lbl">{r.shot}</span>
									<span class="hint">screenshot goes here</span>
								</div>
							)}
						</div>
					</div>
				))}
			</section>

			<section class="wrap features">
				<h2>Your entire reading library, in one place</h2>
				<p class="lead">Organize what you own, discover something new, and keep track of what comes next — all from a server you control.</p>
				<div class="cards">
					{grid.map((g) => (
						<div class="card">
							<div class="icon">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={g.icon}></svg>
							</div>
							<h3>{g.t}</h3>
							<p>{g.d}</p>
						</div>
					))}
				</div>
			</section>

			<section class="wrap tech">
				<h2>Easy to run, built to last</h2>
				<ul class="tech-list">
					{tech.map((t) => (
						<li>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 6"/></svg>
							{t}
						</li>
					))}
				</ul>
			</section>

			<section class="wrap quick">
				<div class="quick-inner">
					<h2>Running in two minutes</h2>
					<p>Point it at your library, give it a data volume, and open the reader.</p>
					<div class="terminal">
						<pre><span class="cmt"># your library folder, plus one volume for data</span>
docker run -d -p 3000:3000 <span class="flag">\</span>
  -v /path/to/library:/content <span class="flag">\</span>
  -v arcagrad-data:/data <span class="flag">\</span>
  ghcr.io/kalining/arcagrad:latest</pre>
					</div>
				</div>
			</section>
		</main>

		<footer>
			<div class="wrap foot">
				<div class="brand"><img class="mark" src="/icon.svg" alt="" width="24" height="24" /> Arcagrad</div>
				<div style="display:flex; gap:22px;">
					<a href="/getting-started/introduction/">Docs</a>
					<a href="/download/">Download</a>
					<a href="/getting-started/install/">Install</a>
					<a href={repo}>GitHub</a>
				</div>
			</div>
		</footer>
	</body>
</html>
